{
  "name": "osint-mcp",
  "version": "0.1.0",
  "description": "OSINT intelligence MCP server — Shodan, VirusTotal, SecurityTrails, Censys, DNS, WHOIS, crt.sh, Wayback, BGP",
  "type": "module",
  "bin": {
    "osint-mcp": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp", "osint", "shodan", "virustotal", "censys", "securitytrails",
    "dns", "whois", "recon", "security", "intelligence",
    "ai", "agent", "model-context-protocol"
  ],
  "author": "Orhan Yildirim <contact@orhanyildirim.us> (https://orhanyildirim.us)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/badchars/osint-mcp.git"
  },
  "homepage": "https://github.com/badchars/osint-mcp",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.2"
  }
}
